# --- WhatsApp Cloud API ---
# Meta for Developers -> your App -> WhatsApp -> API Setup
WA_PHONE_ID=replace-me
WA_TOKEN=replace-me
# Any string you choose; paste the same value into Meta's webhook config UI.
WA_VERIFY_TOKEN=replace-me
# Meta for Developers -> App Settings -> Basic -> App Secret (used to verify webhook signatures)
WA_APP_SECRET=replace-me

# --- Anthropic Claude (Hebrew parsing) ---
ANTHROPIC_API_KEY=sk-ant-replace-me
CLAUDE_MODEL=claude-sonnet-4-6

# --- OpenAI Whisper (voice-to-text) ---
# Optional: leave empty to disable voice notes. Get a key at platform.openai.com.
OPENAI_API_KEY=
WHISPER_MODEL=whisper-1

# --- Database ---
# MVP uses SQLite (zero setup). For production, swap to Postgres, e.g.:
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/shopping
DATABASE_URL=sqlite:///./shopping.db

# --- Message queue ---
# QUEUE_BACKEND=redis  -> run web + `python -m app.worker` as separate processes
# QUEUE_BACKEND=memory -> worker runs in-process; no Redis needed (local/testing only)
QUEUE_BACKEND=redis
REDIS_URL=redis://localhost:6379/0
QUEUE_KEY=shopping:incoming

# --- Misc ---
LOG_LEVEL=INFO
